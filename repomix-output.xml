@import url('https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&family=Playfair+Display:ital,wght@0,400;0,500;0,600;0,700;1,400&family=JetBrains+Mono:wght@400;500&display=swap');
@import "tailwindcss";

@theme {
  --font-sans: "Inter", ui-sans-serif, system-ui, sans-serif;
  --font-serif: "Playfair Display", Georgia, serif;
  --font-mono: "JetBrains Mono", ui-monospace, SFMono-Regular, monospace;
  
  --color-brand-beige: #FAF8F5;
  --color-brand-charcoal: #18181B;
  --color-brand-muted: #71717A;
  
  --color-rose-gold: #D4A373;
  --color-rose-gold-light: #E9D8C6;
  --color-rose-gold-dark: #A77A50;
  
  --color-blush-50: #FFF5F5;
  --color-blush-100: #FFEBEB;
  --color-blush-200: #FFD1D1;
  --color-blush-300: #FFA8A8;
  --color-blush-400: #FF7070;
  --color-blush-500: #E05353;
  
  --animate-fade-in: fade-in 0.8s ease-out forwards;
  --animate-slide-up: slide-up 0.8s ease-out forwards;
}

@keyframes fade-in {
  from { opacity: 0; }
  to { opacity: 1; }
}

@keyframes slide-up {
  from { transform: translateY(20px); opacity: 0; }
  to { transform: translateY(0); opacity: 1; }
}

html {
